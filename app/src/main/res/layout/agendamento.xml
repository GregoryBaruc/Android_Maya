<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_degrade">

    <LinearLayout
        android:id="@+id/topo"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_degrade"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:orientation="horizontal"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_voltar"
            app:tint="@android:color/white" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="AGENDAR CONSULTA"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold" />
    </LinearLayout>

    <CalendarView
        android:id="@+id/CalendarioA"
        android:layout_width="273dp"
        android:layout_height="300dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/topo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <Button
        android:id="@+id/BotaoA1"
        android:backgroundTint="#94E3E9"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/CalendarioA"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:text="10:00"
        />

    <Button
        android:id="@+id/BotaoA2"
        android:backgroundTint="#94E3E9"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="14dp"
        app:layout_constraintTop_toBottomOf="@id/CalendarioA"
        app:layout_constraintEnd_toStartOf="@id/BotaoA1"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:text="9:00"
        />

    <Button
        android:id="@+id/BotaoA3"
        android:backgroundTint="#94E3E9"
        android:layout_width="100dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/BotaoA2"
        app:layout_constraintEnd_toEndOf="@id/BotaoA2"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:text="9:30"
        />

    <Button
        android:id="@+id/BotaoA4"
        android:backgroundTint="#94E3E9"
        android:layout_width="100dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/BotaoA2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:text="10:30"
        />

    <Button
        android:id="@+id/BotaoA5"
        android:backgroundTint="#94E3E9"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginStart="13dp"
        app:layout_constraintTop_toTopOf="@id/BotaoA1"
        app:layout_constraintStart_toEndOf="@id/BotaoA1"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:text="11:00"
        />

    <Button
        android:id="@+id/BotaoA6"
        android:backgroundTint="#94E3E9"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginStart="13dp"
        app:layout_constraintTop_toBottomOf="@id/BotaoA1"
        app:layout_constraintStart_toEndOf="@id/BotaoA1"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:text="11:30"
        />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation2"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="@android:color/white"

        app:menu="@menu/menu_botao2"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/black"
        app:itemTextColor="@color/black"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        />

</androidx.constraintlayout.widget.ConstraintLayout>